#!/usr/bin/env bash

PKGCT_DIR="$HOME/.pkgct"
SYSTEM_BUNDLES="$PKGCT_DIR/system-bundles"
LOCAL_BUNDLES="$PKGCT_DIR/local-bundles"
STATE_FILE="$PKGCT_DIR/state.txt"

mkdir -p "$SYSTEM_BUNDLES" "$LOCAL_BUNDLES" "$(dirname "$STATE_FILE")"

# Load state
if [ -f "$STATE_FILE" ]; then
    . "$STATE_FILE"
else
    scope="system"
    bundle=""
fi

save_state() {
    cat > "$STATE_FILE" <<EOF
scope="$scope"
bundle="$bundle"
EOF
}

# Launch temporary shell with echo-printed visual prompt
launch_shell() {
    while true; do
        # Construct the prompt in red
        if [ -n "$bundle" ]; then
            prompt="\033[31m[$scope:$bundle]\$ \033[0m"
        else
            prompt="\033[31m[$scope]\$ \033[0m"
        fi

        # Read command with prompt, keeping history visible
        read -e -p "$(echo -e $prompt)" cmd

        # Exit on 'exit'
        [ "$cmd" = "exit" ] && break

        # Evaluate the command
        eval "$cmd"
    done
}

cmd_set() {
    scope="$1"
    bundle="$2"
    save_state
    echo "Switched to scope: $scope, bundle: ${bundle:-<none>}"
    launch_shell
}

cmd_list() {
    if [ "$1" = "system" ]; then
        echo "System bundles:"
        ls -1 "$SYSTEM_BUNDLES" 2>/dev/null | sed 's/\.txt$//'
    elif [ "$1" = "local" ]; then
        echo "Local bundles:"
        ls -1 "$LOCAL_BUNDLES" 2>/dev/null | sed 's/\.txt$//'
    else
        echo "Specify: pkgct list system OR pkgct list local"
    fi
}

cmd_set() {
    local new_scope="$1"
    local new_bundle="$2"

    # Validate scope
    if [ "$new_scope" != "system" ] && [ "$new_scope" != "local" ]; then
        echo "Error: Invalid scope. Must be 'system' or 'local'."
        return
    fi

    # If new_bundle is empty, just set scope and clear bundle
    if [ -z "$new_bundle" ]; then
        scope="$new_scope"
        bundle=""

        save_state
        echo "Switched to scope: $scope"
        launch_shell
    else
        # Validate bundle existence
        local bundle_path=""
        if [ "$new_scope" = "system" ]; then
            bundle_path="$SYSTEM_BUNDLES/$new_bundle.txt"
        else
            bundle_path="$LOCAL_BUNDLES/$new_bundle.txt"
        fi

        if [ ! -f "$bundle_path" ]; then
            echo "Error: Bundle '$new_bundle' does not exist in scope '$new_scope'."
            return
        fi

        # Set scope and bundle if valid
        scope="$new_scope"
        bundle="$new_bundle"

        save_state
        echo "Switched to scope: $scope, bundle: $bundle"
        launch_shell
    fi
}

cmd_bundle() {
    # Check if scope is set and non-empty
    if [ -z "$scope" ]; then
        echo "Needs a scope"
        return
    fi

    case "$1" in
    new)
    if [ -z "$2" ]; then
        echo "Usage: pkgct bundle new <bundle>"
        return
    fi
    bundle="$2"
    # Example: create a new bundle file under the selected scope directory
    if [ "$scope" = "system" ]; then
        touch "$SYSTEM_BUNDLES/$bundle.txt"
    elif [ "$scope" = "local" ]; then
        touch "$LOCAL_BUNDLES/$bundle.txt"
    else
        echo "Unknown scope: $scope"
        return
    fi
    save_state
    echo "Created new bundle '$bundle' at scope: $scope"
    ;;
    delete)
    if [ -z "$2" ]; then
        echo "Usage: pkgct bundle delete <bundle>"
        return
    fi
    
    bundle="$2"

    if [ "$scope" = "system" ]; then
        rm -f "$SYSTEM_BUNDLES/$bundle.txt"
    elif [ "$scope" = "local" ]; then
        rm -f "$LOCAL_BUNDLES/$bundle.txt"
    else
        echo "Unknown scope: $scope"
        return
    fi
    save_state
    echo "Deleted bundle '$bundle' at scope: $scope"
    ;;
    add)
    package_or_group="$2"

    if [ -z "$package_or_group" ]; then
        echo "Usage: pkgct bundle add <package|group>"
        return
    fi

    # Inform user we're querying pacman about the package or group
    echo "Querying pacman for '$package_or_group' and its dependencies or group members..."

    # Check if input is a package by querying pacman -Qi (package info)
    if command -v pactree >/dev/null 2>&1 && pacman -Qi "$package_or_group" >/dev/null 2>&1; then
        # pactree is available and input is a package
        echo "Packages that would be installed (including dependencies):"
        pactree -u "$package_or_group"

    # If not a package, check if input is a group by listing group members
    elif pacman -Sg "$package_or_group" >/dev/null 2>&1; then
        echo "Group '$package_or_group' contains the following packages:"
        pacman -Sg "$package_or_group"

    else
        # Neither package nor group found
        echo "Package or group '$package_or_group' not found."
        return
    fi

    # Prompt user to confirm adding the package or group to the bundle
    read -r -p "Do you want to add '$package_or_group' to the bundle? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Validate that a bundle is selected
        if [ -z "$bundle" ]; then
            echo "Error: No bundle selected."
            return
        fi

        # Determine the bundle file path based on scope (system or local)
        if [ "$scope" = "system" ]; then
            bundle_file="$SYSTEM_BUNDLES/$bundle.txt"
        else
            bundle_file="$LOCAL_BUNDLES/$bundle.txt"
        fi

        # Check if the package or group is already listed in the bundle to avoid duplicates
        if grep -qxF "$package_or_group" "$bundle_file"; then
            echo "'$package_or_group' is already in the bundle."
        else
            # Append the package or group to the bundle file
            echo "$package_or_group" >> "$bundle_file"
            echo "'$package_or_group' added to bundle '$bundle'."
        fi
    else
        echo "Aborted adding '$package_or_group'."
    fi
    ;;
    remove)
    package="$2"

    if [ -z "$package" ]; then
        echo "Usage: pkgct bundle remove <package>"
        return
    fi

    # Validate bundle path first
    if [ -z "$bundle" ]; then
        echo "Error: No bundle selected."
        return
    fi

    if [ "$scope" = "system" ]; then
        bundle_file="$SYSTEM_BUNDLES/$bundle.txt"
    else
        bundle_file="$LOCAL_BUNDLES/$bundle.txt"
    fi

    # Check if package exists in bundle
    if ! grep -qxF "$package" "$bundle_file"; then
        echo "Package '$package' is not in the bundle."
        return
    fi

    # Remove the package line exactly and clean up empty lines
    sed -i.bak "/^${package//\//\\/}$/d" "$bundle_file"
    sed -i '/^$/d' "$bundle_file"

    echo "Package '$package' removed from bundle '$bundle'."
    ;;
    install)
    # Validate bundle path first
    if [ -z "$bundle" ]; then
        echo "Error: No bundle selected."
        return
    fi

    if [ "$scope" = "system" ]; then
        bundle_file="$SYSTEM_BUNDLES/$bundle.txt"
    else
        bundle_file="$LOCAL_BUNDLES/$bundle.txt"
    fi

    if [ ! -f "$bundle_file" ]; then
        echo "Error: Bundle file does not exist."
        return
    fi

    # Get packages
    packages=$(cat "$bundle_file")

    if [ -z "$packages" ]; then
        echo "Bundle '$bundle' is empty."
        return
    fi

    echo "Installing/upgrading packages from bundle '$bundle'..."
    sudo pacman -S --needed $packages
    ;;
    unistall)
    # Validate bundle path first
    if [ -z "$bundle" ]; then
        echo "Error: No bundle selected."
        return
    fi

    if [ "$scope" = "system" ]; then
        bundle_file="$SYSTEM_BUNDLES/$bundle.txt"
    else
        bundle_file="$LOCAL_BUNDLES/$bundle.txt"
    fi

    if [ ! -f "$bundle_file" ]; then
        echo "Error: Bundle file does not exist."
        return
    fi

    # Get packages
    packages=$(cat "$bundle_file")

    if [ -z "$packages" ]; then
        echo "Bundle '$bundle' is empty."
        return
    fi

    echo "Uninstalling packages from bundle '$bundle'..."
    sudo pacman -R $packages
    ;;
    export)
    # Check if a bundle name is provided
    if [ -z "$2" ]; then
        echo "Usage: pkgct bundle export <bundle>"
        return
    fi

    local export_bundle="$2"
    local source_file=""

    # Determine source file based on current scope
    if [ "$scope" = "system" ]; then
        source_file="$SYSTEM_BUNDLES/$export_bundle.txt"
    elif [ "$scope" = "local" ]; then
        source_file="$LOCAL_BUNDLES/$export_bundle.txt"
    fi

    # Check if source bundle exists
    if [ ! -f "$source_file" ]; then
        echo "Bundle '$export_bundle' does not exist in scope '$scope'."
        return
    fi

    # Define destination path in Downloads folder
    local downloads_dir="$HOME/Downloads"
    mkdir -p "$downloads_dir"

    local dest_file="$downloads_dir/$export_bundle.txt"

    # Copy the bundle file to Downloads
    cp "$source_file" "$dest_file"

    if [ $? -eq 0 ]; then
        echo "Exported bundle '$export_bundle' to $dest_file"
    else
        echo "Failed to export bundle '$export_bundle'."
    fi
    ;;
    list)
    if [ -z "$2" ]; then
        echo "Usage: pkgct bundle list <bundle>"
        return
    fi

    local list_bundle="$2"
    local bundle_file=""

    if [ "$scope" = "system" ]; then
        bundle_file="$SYSTEM_BUNDLES/$list_bundle.txt"
    elif [ "$scope" = "local" ]; then
        bundle_file="$LOCAL_BUNDLES/$list_bundle.txt"
    fi

    if [ ! -f "$bundle_file" ]; then
        echo "Bundle '$list_bundle' does not exist in scope '$scope'."
        return
    fi

    echo "Bundle $list_bundle packages:"
    cat "$bundle_file"
    ;;
    *)
    echo "Usage: pkgct bundle {new|delete|add|remove|install|unistall|export|list} <bundle>"
    ;;
    esac
}

# Dispatcher
case "$1" in
    init) launch_shell ;;
    list) cmd_list "$2" ;;
    set) cmd_set "$2" "$3" ;;
    bundle) cmd_bundle "$2" "$3" ;;
    *) echo "Usage: pkgct {init|list|set|bundle}" ;;
esac